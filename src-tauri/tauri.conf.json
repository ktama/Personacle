{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personacle",
  "version": "0.1.0",
  "identifier": "com.personacle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Personacle",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "copyright": "© 2026 ktama",
    "licenseFile": "../LICENSE"
  }
}
